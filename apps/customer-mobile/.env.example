# Supabase (required for auth/storage)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Backend API base URL (no /api suffix — the app adds /api for requests).
# - Production: https://weyouapi.krackbot.com
# - Local: phone on WiFi → PC LAN IP, e.g. http://192.168.1.3:3009
# - Android emulator: http://10.0.2.2:PORT  |  iOS Simulator: http://localhost:PORT
# After changing, restart Expo (npx expo start -c). EAS preview/production use eas.json env.

EXPO_PUBLIC_API_URL=https://weyouapi.krackbot.com
