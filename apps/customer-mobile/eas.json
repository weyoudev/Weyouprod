{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "base": {
      "node": "20.19.4"
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "PRISMA_SKIP_POSTINSTALL_GENERATE": "1",
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "EAS_BUILD_NO_EXPO_GO_WARNING": "1"
      }
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "env": {
        "PRISMA_SKIP_POSTINSTALL_GENERATE": "1",
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "EAS_BUILD_NO_EXPO_GO_WARNING": "1",
        "EXPO_PUBLIC_API_URL": "https://weyouapi.krackbot.com/api"
      },
      "android": {
        "buildType": "apk"
      },
      "channel": "preview"
    },
    "production": {
      "extends": "base",
      "env": {
        "PRISMA_SKIP_POSTINSTALL_GENERATE": "1",
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "EAS_BUILD_NO_EXPO_GO_WARNING": "1",
        "EXPO_PUBLIC_API_URL": "https://weyouapi.krackbot.com/api"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {}
  }
}
