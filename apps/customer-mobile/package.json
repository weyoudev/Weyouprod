{
  "name": "customer-mobile",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start -c",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android:beta": "node scripts/update-icon-from-branding.js && eas build --platform android --profile preview",
    "build:android:production": "node scripts/update-icon-from-branding.js && eas build --platform android --profile production",
    "build:android:apk": "node scripts/update-icon-from-branding.js && eas build --platform android --profile preview",
    "build:ios:beta": "eas build --platform ios --profile preview",
    "build:ios:production": "eas build --platform ios --profile production",
    "update-icon-from-branding": "node scripts/update-icon-from-branding.js"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@supabase/supabase-js": "^2.95.3",
    "base64-arraybuffer": "^1.0.2",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-linear-gradient": "~15.0.8",
    "expo-notifications": "~0.32.16",
    "expo-print": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
